{
  "name": "mimmi20/ios-build",
  "description": "Class wrapper for peterkahl/apple-ios-build-version",
  "license": "MIT",
  "type": "library",
  "authors": [
    {
      "name": "Thomas Müller",
      "homepage": "https://github.com/mimmi20",
      "role": "Developer"
    },
    {
      "name": "Contributors",
      "homepage": "https://github.com/mimmi20/ios-build/graphs/contributors"
    }
  ],
  "homepage": "https://github.com/mimmi20/ios-build",
  "support": {
    "issues": "https://github.com/mimmi20/ios-build/issues",
    "source": "https://github.com/mimmi20/ios-build"
  },
  "require": {
    "php": "~8.5.0 || ~8.6.0"
  },
  "require-dev": {
    "ext-ctype": "*",
    "ext-dom": "*",
    "ext-mbstring": "*",
    "ext-simplexml": "*",
    "ext-tokenizer": "*",
    "ext-xml": "*",
    "ext-xmlwriter": "*",
    "ergebnis/composer-normalize": "^2.52.0",
    "infection/infection": "^0.33.2",
    "jbelien/phpstan-sarif-formatter": "^1.2.0",
    "mimmi20/coding-standard": "^8.0.3",
    "nikic/php-parser": "^5.7.0",
    "phpstan/extension-installer": "^1.4.3",
    "phpstan/phpstan": "^2.2.2",
    "phpstan/phpstan-deprecation-rules": "^2.0.4",
    "phpstan/phpstan-phpunit": "^2.0.16",
    "phpunit/phpunit": "^13.1.8",
    "rector/rector": "^2.4.5",
    "rector/type-perfect": "^2.1.4",
    "shipmonk/composer-dependency-analyser": "^1.8.4",
    "symfony/process": "^8.1.0",
    "symplify/phpstan-rules": "^14.10.0",
    "tomasvotruba/cognitive-complexity": "^1.1.1",
    "tomasvotruba/type-coverage": "^2.2.1",
    "tomasvotruba/unused-public": "^2.2.0"
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "autoload": {
    "psr-4": {
      "IosBuild\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "IosBuildTest\\": "tests/"
    }
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true,
      "ergebnis/composer-normalize": true,
      "infection/extension-installer": true,
      "phpstan/extension-installer": true
    },
    "lock": false,
    "preferred-install": "dist",
    "sort-packages": true
  },
  "extra": {
    "composer-normalize": {
      "indent-size": 2,
      "indent-style": "space"
    }
  }
}
